{
  "name": "bgfx-shader-analyzer",
  "displayName": "bgfx_shader_analyzer",
  "description": "Completion, goto-definition, inline documentation and formatter for bgfx shader files (.sc).",
  "repository": {
    "url": "https://github.com/r0ckHopper/bgfx_shader_analyzer-vscode"
  },
  "publisher": "Rockhopper",
  "author": {
    "name": "RockHopper",
    "url": "https://github.com/r0ckHopper"
  },
  "version": "0.1.0",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.83.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:bgfx-shader"
  ],
  "main": "./out/main.js",
  "keywords": [
    "language server",
    "completion",
    "documentation",
    "bgfx",
    "shader",
    "sc"
  ],
  "contributes": {
    "languages": [
      {
        "id": "bgfx-shader",
        "aliases": [
          "bgfx Shader",
          "bgfx-shader"
        ],
        "extensions": [
          ".sc",
          ".glsl",
          ".vert",
          ".frag",
          ".geom",
          ".tesc",
          ".tese",
          ".comp",
          ".mesh",
          ".task",
          ".rgen",
          ".rint",
          ".rahit",
          ".rchit",
          ".rmiss",
          ".rcall",
          ".vs",
          ".fs",
          ".gs",
          ".vsh",
          ".fsh",
          ".gsh",
          ".csh"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "bgfx-shader-analyzer.stopClient",
        "title": "bgfx: Stop bgfx_shader_analyzer"
      },
      {
        "command": "bgfx-shader-analyzer.restartClient",
        "title": "bgfx: Restart bgfx_shader_analyzer"
      },
      {
        "command": "bgfx-shader-analyzer.download",
        "title": "bgfx: Download latest bgfx_shader_analyzer"
      },
      {
        "command": "bgfx-shader-analyzer.version",
        "title": "bgfx: Get version of bgfx_shader_analyzer"
      }
    ],
    "configuration": {
      "title": "bgfx_shader_analyzer",
      "properties": {
        "bgfx-shader-analyzer.path": {
          "scope": "machine",
          "type": "string",
          "description": "Path to the `bgfx_shader_analyzer` executable.",
          "format": "path"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/main.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "test-compile": "tsc -p ./"
  },
  "dependencies": {
    "@types/adm-zip": "^0.5.2",
    "adm-zip": "^0.5.10",
    "axios": "^1.5.1",
    "mkdirp": "^3.0.1",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.2",
    "@types/node": "18.x",
    "@types/vscode": "^1.83.0",
    "@typescript-eslint/eslint-plugin": "^6.7.3",
    "@typescript-eslint/parser": "^6.7.3",
    "@vscode/test-electron": "^2.3.4",
    "esbuild": "^0.19.4",
    "eslint": "^8.50.0",
    "glob": "^10.3.3",
    "mocha": "^10.2.0",
    "typescript": "^5.2.2"
  }
}
